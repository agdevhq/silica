{
  "name": "silica-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Silica framework monorepo",
  "type": "module",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "dev": "turbo watch build --filter=docs^... & turbo run dev --filter=docs",
    "e2e": "npm run build && playwright test",
    "generated-app-manifest:check": "node scripts/sync-generated-app-manifest.mjs --check",
    "generated-app-manifest:update": "node scripts/sync-generated-app-manifest.mjs --write",
    "lint": "turbo run lint",
    "perf:large-vault:build": "npm run perf:large-vault:build --workspace docs",
    "perf:large-vault:dev": "npm run perf:large-vault:dev --workspace docs",
    "perf:large-vault:generate": "npm run perf:large-vault:generate --workspace docs",
    "perf:large-vault:measure": "npm run perf:large-vault:measure --workspace docs",
    "release:check": "npm run scaffold-versions:check && npm run generated-app-manifest:check && npm run format && npm run build && npm run lint && npm run typecheck && npm test",
    "release:publish": "changeset publish",
    "release:version": "changeset version && npm run scaffold-versions:update && npm run generated-app-manifest:update",
    "scaffold-versions:check": "node scripts/sync-scaffold-versions.mjs --check",
    "scaffold-versions:update": "node scripts/sync-scaffold-versions.mjs --write",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "prettier": "^3.9.3",
    "tsup": "^8.5.1",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
