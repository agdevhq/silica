{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "docs/**/*.ts",
    "docs/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/.silica",
    "**/.next",
    "packages/next/src/template-files"
  ]
}
