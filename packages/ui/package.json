{
  "name": "@silicajs/ui",
  "version": "0.2.0",
  "description": "Generic shadcn-style component library for Silica themes. Base UI primitives + Tailwind v4.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./components/*": "./src/components/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "files": [
    "src",
    "components.json",
    "postcss.config.mjs"
  ],
  "scripts": {
    "shadcn": "shadcn",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "echo \"no tests\"",
    "build": "echo \"@silicajs/ui ships from src; no build\""
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "react-resizable-panels": "^4.11.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.1.18"
  },
  "homepage": "https://github.com/agdevhq/silica/tree/main/packages/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agdevhq/silica.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/agdevhq/silica/issues"
  }
}
