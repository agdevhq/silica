{
  "name": "@silicajs/components",
  "version": "0.1.0",
  "description": "Silica-aware, framework-agnostic React composables built on @silicajs/ui.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "import": "./dist/routing.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@silicajs/core": "0.1.0",
    "@silicajs/ui": "0.1.0",
    "lucide-react": "^1.16.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1"
  }
}
