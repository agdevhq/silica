{
  "name": "@silicajs/core",
  "version": "0.4.0",
  "description": "Markdown pipeline, slug system, and precompute artifacts for Silica.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@shikijs/rehype": "^4.1.0",
    "@silicajs/remark-obsidian": "^0.1.0",
    "@silicajs/search": "^0.2.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "jiti": "^2.7.0",
    "katex": "^0.17.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-react": "^8.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.1.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "devDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.7"
  },
  "homepage": "https://github.com/agdevhq/silica/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agdevhq/silica.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/agdevhq/silica/issues"
