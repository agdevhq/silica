    "@silicajs/core": "^0.8.0",
    "@silicajs/next": "^0.5.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5"
  },
  "homepage": "https://github.com/agdevhq/silica/tree/main/packages/cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agdevhq/silica.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/agdevhq/silica/issues"
