{
  "name": "@silicajs/remark-obsidian",
  "version": "0.1.0",
  "description": "Remark plugin for Obsidian-flavored Markdown extensions.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "homepage": "https://github.com/agdevhq/silica/tree/main/packages/remark-obsidian#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agdevhq/silica.git",
    "directory": "packages/remark-obsidian"
  },
  "bugs": {
    "url": "https://github.com/agdevhq/silica/issues"
  },
  "keywords": [
    "remark",
    "unified",
    "micromark",
    "markdown",
    "obsidian",
    "wikilink",
    "callout"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/mdast": "^4.0.4",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-factory-space": "^2.0.1",
    "micromark-util-character": "^2.1.1",
    "micromark-util-types": "^2.0.2",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  }
}
