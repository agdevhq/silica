{
  "name": "@silicajs/assistant",
  "version": "0.0.0",
  "description": "Optional AI assistant for Silica knowledge sites — core-ai runtime, constrained markdown tools, and theme-consumable UI.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@core-ai/core-ai": "^0.11.0",
    "@silicajs/components": "^0.3.1",
    "@silicajs/core": "^0.7.1",
    "@silicajs/ui": "^0.1.3",
    "just-bash": "^3.0.1",
    "lucide-react": "^1.17.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@silicajs/next": "^0.4.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1"
  },
  "homepage": "https://github.com/agdevhq/silica/tree/main/packages/assistant#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agdevhq/silica.git",
    "directory": "packages/assistant"
  },
  "bugs": {
    "url": "https://github.com/agdevhq/silica/issues"
  }
}
