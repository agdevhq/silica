{
  "name": "@silicajs/components",
  "version": "0.4.1",
  "description": "Silica-aware, framework-agnostic React composables built on @silicajs/ui.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "import": "./dist/routing.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@silicajs/core": "^0.9.0",
    "@silicajs/remark-obsidian": "^0.1.0",
    "@silicajs/ui": "^0.2.1",
    "lucide-react": "^1.21.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1"
  },
  "homepage": "https://github.com/agdevhq/silica/tree/main/packages/components#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agdevhq/silica.git",
    "directory": "packages/components"
  },
  "bugs": {
    "url": "https://github.com/agdevhq/silica/issues"
  }
}
