{
  "name": "@silicajs/create",
  "version": "0.1.1",
  "description": "Scaffold a new Silica vault.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "silicajs-create": "./dist/bin.js"
  },
